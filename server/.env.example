# ---- Turso / libSQL configuration ----
# For a LIVE Turso database, set both of these (from `turso db show` and `turso db tokens create`):
#   TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
#   TURSO_AUTH_TOKEN=your-long-lived-token
#
# If these are left blank, the app uses a local libSQL file (data/expohub.db),
# which is the SAME engine Turso runs on — so the demo works 100% offline too.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local fallback file (used only when TURSO_DATABASE_URL is empty)
LOCAL_DB_FILE=file:./data/expohub.db

# Auth
JWT_SECRET=expohub-dev-secret-change-me
JWT_EXPIRES_IN=7d

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
